  "description": "Shadow NDR Multi-Tenant Backend - Ultimate Production Server",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --watch src src/server.js",
    "dev:debug": "nodemon --inspect --watch src src/server.js",
    "test": "node --test",
    "lint": "eslint src/",
