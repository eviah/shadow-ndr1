# Shadow NDR - environment template
# Copy to .env and populate with strong random values:
#   openssl rand -hex 32   (for secrets)
#   openssl rand -base64 24  (for passwords)
# .env MUST be gitignored.

# ---- Database ----
POSTGRES_DB=shadow_ndr
POSTGRES_USER=shadow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ---- ClickHouse ----
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME_STRONG_CLICKHOUSE_PASSWORD

# ---- Grafana ----
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# ---- shadow-api ----
SHADOW_API_SECRET_KEY=CHANGE_ME_64_HEX_CHARS
SHADOW_API_JWT_SECRET=CHANGE_ME_64_HEX_CHARS

# ---- shadow-ml ----
SHADOW_ML_JWT_SECRET=CHANGE_ME_64_HEX_CHARS
# Comma-separated bcrypt-hashed API keys (use scripts/generate_api_key.py)
SHADOW_ML_API_KEYS=
# Comma-separated CORS origins
SHADOW_ML_CORS_ORIGINS=http://localhost:3000,http://localhost:3002
SHADOW_ML_TRUSTED_HOSTS=localhost,127.0.0.1,shadow-ml
# production | development
SHADOW_ENV=production
# Disable Swagger docs when production (1=disable)
SHADOW_DISABLE_DOCS=1
# Enable real trained baseline model (1=yes)
SHADOW_USE_REAL_MODEL=1

# ---- Anthropic (RAG) ----
ANTHROPIC_API_KEY=

# ---- Tripwire alerts (optional) ----
SHADOW_ALERT_WEBHOOK_URL=
