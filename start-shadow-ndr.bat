@echo off
title Shadow NDR Launcher
color 0A

echo ??????????????????????????????????????????????????????????????????
echo ?              SHADOW NDR - SYSTEM LAUNCHER                     ?
echo ??????????????????????????????????????????????????????????????????
echo.

:: ========================================
:: 1. ????? ??????? ??????
:: ========================================
echo [1/6] Stopping existing processes...
taskkill /F /IM node.exe >nul 2>&1
taskkill /F /IM shadow-sensor.exe >nul 2>&1
timeout /t 2 /nobreak >nul
echo        ? Done
echo.

:: ========================================
:: 2. ????? Docker
:: ========================================
echo [2/6] Starting Docker containers...
cd /d C:\Users\liorh\shadow-ndr\multi-tenant
docker-compose up -d >nul 2>&1
timeout /t 5 /nobreak >nul
echo        ? PostgreSQL + Redis running
echo.

:: ========================================
:: 3. ????? Backend (???? ???)
:: ========================================
echo [3/6] Starting Backend API...
start "Shadow NDR - Backend" cmd /k "cd /d C:\Users\liorh\shadow-ndr\multi-tenant\backend && echo [BACKEND] Starting on port 3001... && npm run dev"
timeout /t 3 /nobreak >nul
echo        ? Backend starting (port 3001)
echo.

:: ========================================
:: 4. ????? Frontend (???? ???)
:: ========================================
echo [4/6] Starting Frontend...
start "Shadow NDR - Frontend" cmd /k "cd /d C:\Users\liorh\shadow-ndr\multi-tenant\frontend && echo [FRONTEND] Starting on port 3000... && npm run dev"
timeout /t 2 /nobreak >nul
echo        ? Frontend starting (port 3000)
echo.

:: ========================================
:: 5. ????? ?-Backend
:: ========================================
echo [5/6] Waiting for backend to be ready...
:wait_loop
timeout /t 2 /nobreak >nul
curl -s http://localhost:3001/health >nul 2>&1
if %errorlevel% neq 0 goto wait_loop
echo        ? Backend is ready
echo.

:: ========================================
:: 6. ????? Sensor (????? - ????? ???)
:: ========================================
echo [6/6] Starting Sensor (Administrator mode)...
powershell -Command "Start-Process cmd -ArgumentList '/k cd /d C:\Users\liorh\shadow-ndr\shadow-sensor && echo [SENSOR] Starting packet capture... && set RUST_LOG=debug && .\target\release\shadow-sensor.exe' -Verb RunAs"
echo        ? Sensor starting in new window
echo.

